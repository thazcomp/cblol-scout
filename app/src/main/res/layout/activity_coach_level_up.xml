<?xml version="1.0" encoding="utf-8"?>
<!--
    Tela de level up do técnico.

    Layout dramático estilo Football Manager / Pro Evolution:
      - Background dourado com gradiente (animado pra dar sensação de raio)
      - "LEVEL UP!" enorme no topo
      - Level antigo → Level novo (animação de scale)
      - Título atual (Iniciante/Profissional/Lendário/...)
      - Se é milestone: badge desbloqueada (emoji 80sp) + nome + descrição
      - Lista de bônus aplicados (bullets)
      - Se NÃO é milestone: mensagem "continue evoluindo, próximo marco no level X"
      - Botão CONTINUAR

    A activity é apresentada a partir do ManagerHub.onResume quando
    GameState.pendingCoachLevelUps tem elementos — consome UM por vez.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <!-- Headline: "LEVEL UP!" dourado em destaque -->
        <TextView
            android:id="@+id/tv_levelup_headline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/coach_levelup_headline"
            android:textColor="@color/champion_gold"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:gravity="center"/>

        <!-- Faixa de progresso de level: "Nv 4  →  Nv 5" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_levelup_old_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="20sp"
                tools:text="Nv 4"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:text="→"
                android:textColor="@color/champion_gold"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_levelup_new_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/champion_gold"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="Nv 5"/>
        </LinearLayout>

        <!-- Título derivado do level novo: "Profissional", "Veterano"... -->
        <TextView
            android:id="@+id/tv_levelup_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/color_on_surface"
            android:textSize="16sp"
            android:textStyle="italic"
            tools:text="Promissor"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@color/color_outline_variant"/>

        <!--
          CASO MILESTONE: badge gigante + nome + descrição + lista de bônus.
          A Activity esconde este bloco quando o level NÃO é milestone.
        -->
        <LinearLayout
            android:id="@+id/ll_milestone_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/coach_levelup_badge_unlocked"
                android:textColor="@color/color_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

            <TextView
                android:id="@+id/tv_levelup_badge_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="80sp"
                tools:text="🎲"/>

            <TextView
                android:id="@+id/tv_levelup_badge_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/champion_gold"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Tático"/>

            <TextView
                android:id="@+id/tv_levelup_badge_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.35"
                tools:text="Você lê o jogo. Aparece mais uma sugestão no pick &amp; ban."/>

            <!--
              Lista de bullets dos bônus passivos. Preenchida em Kotlin
              porque a quantidade varia por milestone (1 a 5 bullets).
            -->
            <LinearLayout
                android:id="@+id/ll_levelup_bullets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"/>
        </LinearLayout>

        <!--
          CASO NÃO-MILESTONE: mensagem "continue evoluindo, próximo marco no
          level X". A Activity esconde este bloco quando o level É milestone.
        -->
        <LinearLayout
            android:id="@+id/ll_intermediate_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈"
                android:textSize="64sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/coach_levelup_intermediate"
                android:textColor="@color/color_on_surface"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"/>

            <TextView
                android:id="@+id/tv_levelup_next_milestone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/champion_gold"
                android:textSize="13sp"
                android:textStyle="italic"
                tools:text="Próximo marco: Nv 7 · 🧠 Mente Estratégica"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_levelup_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp"
            android:text="@string/coach_levelup_continue"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="@color/color_primary"
            app:cornerRadius="14dp"/>

    </LinearLayout>
</ScrollView>
