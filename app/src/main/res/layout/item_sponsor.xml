<?xml version="1.0" encoding="utf-8"?>
<!--
    Card de patrocínio. Visualmente:

      ┌─────────────────────────────────────────────────────┐
      │ ⚡  VoltKick Energy                  💎 Diamante     │
      │     Energético · 6 semanas restantes                │
      │     ─────────────────────────────                   │
      │     R$ 80.000/semana                                │
      │     Descrição opcional...                           │
      │     [ Bônus +R$15k/vit · Multa -R$60k/derrota ]     │
      │                            [   AÇÃO PRIMÁRIA   ]    │
      └─────────────────────────────────────────────────────┘
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_outline_gold"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Barra colorida lateral conforme o tier do patrocínio -->
        <View
            android:id="@+id/view_tier_bar"
            android:layout_width="4dp"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Linha 1: categoria icon + nome + tier badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_category_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tv_sponsor_name"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="10dp" />

                <TextView
                    android:id="@+id/tv_tier_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/color_on_primary" />
            </LinearLayout>

            <!-- Linha 2: subtítulo (categoria · status) -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <!-- Linha 3: valor semanal -->
            <TextView
                android:id="@+id/tv_weekly_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/champion_gold"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />

            <!-- Linha 4: descrição (apenas no card de oferta, escondido em ativos) -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp"
                android:visibility="gone" />

            <!-- Linha 5: chips de bônus/penalidade -->
            <LinearLayout
                android:id="@+id/ll_bonuses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_bonus_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/state_success"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_penalty_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/state_danger"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Linha 6: botões de ação -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:visibility="gone"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/state_danger"
                    android:textColor="@color/state_danger"
                    app:cornerRadius="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginStart="8dp"
                    app:backgroundTint="@color/champion_gold"
                    android:textColor="@color/pick_ban_bg"
                    app:cornerRadius="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
