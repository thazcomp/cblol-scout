<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout do dialog que mostra o histórico de mudanças de moral de um jogador.

    Estrutura:
      ┌─────────────────────────────────────────────┐
      │ 😄  Robo                                    │
      │     Moral: 78 / 100 (Feliz)                 │
      │ ────────────────────────────────────────    │
      │ HISTÓRICO RECENTE                           │
      │  +5   Vitória contra LOUD       18/05/2026  │
      │  +5   Vitória contra Vivo       16/05/2026  │
      │ -15   Rebaixado para reserva    10/05/2026  │
      │ +20   Contrato renovado         02/05/2026  │
      │  ⚠   Pediu transferência        28/04/2026  │
      └─────────────────────────────────────────────┘

    Lista vazia mostra mensagem "Sem mudanças recentes".
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: emoji + nome + valor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_mood_emoji"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:textSize="36sp"
                android:gravity="center"
                android:background="@color/champion_slot_bg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_player_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/champion_gold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_mood_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_on_surface_variant"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Barra de moral -->
        <ProgressBar
            android:id="@+id/pb_mood"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginHorizontal="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/champion_gold"
            android:progressBackgroundTint="#33C9AA71" />

        <!-- Flag de pedido de transferência (visível só quando aplicável) -->
        <TextView
            android:id="@+id/tv_transfer_request"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mood_dialog_transfer_request"
            android:textColor="@color/state_danger"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:visibility="gone"
            android:background="@color/champion_slot_bg" />

        <!-- Cabeçalho do histórico -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mood_dialog_history_header"
            android:textColor="@color/champion_gold"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="8dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp" />

        <!-- Lista de eventos (preenchida dinamicamente) -->
        <LinearLayout
            android:id="@+id/ll_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />

        <!-- Mensagem de "sem eventos" (visível só quando lista vazia) -->
        <TextView
            android:id="@+id/tv_history_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mood_dialog_history_empty"
            android:textColor="@color/color_on_surface_variant"
            android:textSize="12sp"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
