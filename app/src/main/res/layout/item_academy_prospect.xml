<?xml version="1.0" encoding="utf-8"?>
<!--
    item_academy_prospect.xml
    Card de um prospect da categoria de base.

      ┌────────────────────────────────────────────────┐
      │ ▌ MID · Pétala            16 anos    OVR 58     │
      │   Lucas Silva                                    │
      │   Potencial: Alto (oculto) / 84                  │
      │   [████████░░░░] 69% desenvolvido                │
      │   [AVALIAR]  [PROMOVER]  [⋯]                      │
      └────────────────────────────────────────────────┘

    A barra lateral fica verde quando o prospect está pronto para subir.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_outline_variant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/color_surface_elevated">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/view_accent_bar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/color_outline_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Linha 1: role · nome + idade + overall -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_prospect_name"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_prospect_age"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:textColor="@color/color_on_surface_variant"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_prospect_overall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/champion_gold"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Nome real -->
            <TextView
                android:id="@+id/tv_prospect_realname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="12sp" />

            <!-- Potencial -->
            <TextView
                android:id="@+id/tv_prospect_potential"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Barra de desenvolvimento -->
            <ProgressBar
                android:id="@+id/pb_prospect_dev"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progressTint="@color/state_success"
                android:progressBackgroundTint="@color/color_outline_variant" />

            <TextView
                android:id="@+id/tv_prospect_dev_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="11sp" />

            <!-- Ações -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_evaluate"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:layout_marginEnd="4dp"
                    android:text="@string/academy_evaluate"
                    android:textSize="11sp"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_promote"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:layout_marginHorizontal="4dp"
                    android:text="@string/academy_promote"
                    android:textSize="11sp"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_release"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="4dp"
                    android:text="@string/academy_release"
                    android:textColor="@color/state_danger"
                    android:textSize="11sp"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
