<?xml version="1.0" encoding="utf-8"?>
<!--
    Card de AJUDA exibido após as 3 sugestões de pick na faixa horizontal.

    Mostra um grande "?" e um rótulo curto. Tocar abre o mesmo dialog de
    sugestão de composições do botão "?" no topo da tela (CompSuggestionDialog),
    dando ao treinador acesso rápido às composições recomendadas sem precisar
    ir até o topo.

    Mantém a mesma largura/altura dos cards de sugestão para alinhar a faixa.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="6dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/pick_ban_suggestion_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:minHeight="110dp">

        <!-- Círculo dourado com "?" -->
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/pick_ban_bg"
            android:textSize="26sp"
            android:textStyle="bold"
            android:background="@drawable/bg_help_button" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/pb_suggestion_help_card_title"
            android:textColor="@color/champion_gold"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="@string/pb_suggestion_help_card_subtitle"
            android:textColor="#CCFFFFFF"
            android:textSize="9sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.05" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
