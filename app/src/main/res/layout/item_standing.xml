<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp">

    <TextView android:id="@+id/tv_st_pos"
        android:layout_width="32dp" android:layout_height="wrap_content"
        android:textSize="15sp" android:fontFamily="sans-serif-bold"
        android:gravity="center"/>

    <View android:id="@+id/view_st_color"
        android:layout_width="4dp" android:layout_height="24dp"
        android:layout_marginStart="2dp" android:layout_marginEnd="8dp"/>

    <TextView android:id="@+id/tv_st_team"
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="@color/color_on_surface"/>

    <TextView android:id="@+id/tv_st_w"
        android:layout_width="36dp" android:layout_height="wrap_content"
        android:textSize="14sp" android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_on_surface"/>

    <TextView android:id="@+id/tv_st_l"
        android:layout_width="36dp" android:layout_height="wrap_content"
        android:textSize="14sp" android:gravity="center"
        android:textColor="@color/color_on_surface_variant"/>

    <TextView android:id="@+id/tv_st_diff"
        android:layout_width="48dp" android:layout_height="wrap_content"
        android:textSize="13sp" android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_on_surface_variant"/>
</LinearLayout>
