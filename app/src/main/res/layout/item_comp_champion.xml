<?xml version="1.0" encoding="utf-8"?>
<!--
    item_comp_champion.xml
    Mini-card de um campeão-chave dentro de um card de composição no dialog
    de sugestões. Mostra imagem circular + nome curto abaixo.

    Largura fixa de 52dp para caber ~5-6 numa linha horizontal scrollável.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="52dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_marginEnd="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/color_outline_gold"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/iv_comp_champion"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/champ_icon_desc" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_comp_champion_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textColor="@color/color_on_surface"
        android:textSize="8sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
