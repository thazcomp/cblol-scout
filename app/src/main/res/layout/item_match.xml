<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="3dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View android:id="@+id/view_match_round_bar"
            android:layout_width="4dp"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_match_round"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_on_surface_variant"/>
                <View android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="0dp"/>
                <TextView android:id="@+id/tv_match_date"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/color_on_surface_variant"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <View android:id="@+id/view_match_home_color"
                    android:layout_width="4dp"
                    android:layout_height="20dp"/>

                <TextView android:id="@+id/tv_match_home"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_on_surface"
                    android:layout_marginStart="6dp"/>

                <TextView android:id="@+id/tv_match_score"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="16sp" android:fontFamily="sans-serif-bold"
                    android:textColor="@color/color_on_surface"
                    android:paddingHorizontal="10dp"/>

                <TextView android:id="@+id/tv_match_away"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/color_on_surface"
                    android:gravity="end"
                    android:layout_marginEnd="6dp"/>

                <View android:id="@+id/view_match_away_color"
                    android:layout_width="4dp"
                    android:layout_height="20dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
