<?xml version="1.0" encoding="utf-8"?>
<!--
    Item reutilizável para uma barra de atributo no perfil do técnico.

    Estrutura:
      Liderança              72
      ████████████░░░░░░

    Usado pelo CoachProfileDialog via <include /> 5 vezes
    (Liderança, Drafting, Gestão Financeira, Olho para Talentos, Reputação).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_attr_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/color_on_surface"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_attr_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/champion_gold"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_attr_bar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="2dp"
        android:max="99"
        android:progress="0"
        android:progressTint="@color/champion_gold"
        android:progressBackgroundTint="#22C9AA71" />
</LinearLayout>
