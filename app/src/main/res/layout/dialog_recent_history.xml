<?xml version="1.0" encoding="utf-8"?>
<!--
  Dialog do histórico completo da carreira.

  Estrutura:
    - Header com título + botão "limpar filtros" (visível quando há filtro ativo)
    - Linha rolável de chips de filtro por categoria (HorizontalScrollView)
    - RecyclerView vertical com TODOS os eventos, sem limite (scroll)
    - Estado vazio (quando filtros resultam em zero eventos)

  Sem altura fixa — usa wrap_content com altura máxima implícita do dialog
  para permitir que a lista cresça enquanto houver espaço, e tenha scroll
  quando ultrapassar.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/recent_history_dialog_title"
            android:textColor="@color/champion_gold"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>

        <TextView
            android:id="@+id/tv_clear_filters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_history_clear_filters"
            android:textColor="@color/color_primary"
            android:textSize="12sp"
            android:padding="6dp"
            android:background="?attr/selectableItemBackground"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Chips de filtro -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/ll_filter_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_outline_variant"/>

    <!-- Conteúdo: lista ou empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_history"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="4dp"
            tools:listitem="@layout/item_recent_history"/>

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="32dp"
            android:textColor="@color/color_on_surface_variant"
            android:textSize="13sp"
            android:text="@string/recent_history_empty"
            android:visibility="gone"/>
    </FrameLayout>
</LinearLayout>
