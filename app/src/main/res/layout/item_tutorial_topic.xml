<?xml version="1.0" encoding="utf-8"?>
<!--
    Card de um tópico do tutorial na lista (TutorialActivity).

    Layout simples e denso:
      [emoji 32sp]  Título (15sp bold)              [chevron ›]
                    Resumo curto (12sp)

    A chevron à direita reforça que é clicável (abre o detalhe).
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="6dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_outline_variant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_tutorial_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:layout_marginEnd="14dp"
            tools:text="🎯"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tutorial_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Conceitos básicos"/>

            <TextView
                android:id="@+id/tv_tutorial_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/color_on_surface_variant"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="O que é um split, BO3, divisões e o ciclo de jogo."/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="@color/color_primary"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
