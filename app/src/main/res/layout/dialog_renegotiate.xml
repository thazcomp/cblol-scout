<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog de renegociação de contrato.

    Campos:
      - Salário mensal proposto
      - Bônus de assinatura (compensa salário menor — aumenta a aceitação)
      - Nova data de término

    Área de info (preenchida em código): mostra o status do contrato atual
    (Ativo/Expirando/Expirado), a multa rescisória vigente e os dias restantes.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Card de info do contrato atual -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@color/champion_slot_bg"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_contract_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/champion_gold"/>

            <TextView
                android:id="@+id/tv_contract_release"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/color_on_surface_variant"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/renegotiate_salary_label"
            android:textSize="12sp"
            android:textColor="@color/color_on_surface_variant"/>

        <EditText
            android:id="@+id/et_new_salary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textSize="16sp"
            android:textColor="@color/color_on_surface"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/renegotiate_bonus_label"
            android:textSize="12sp"
            android:textColor="@color/color_on_surface_variant"/>

        <EditText
            android:id="@+id/et_signing_bonus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textSize="16sp"
            android:textColor="@color/color_on_surface"
            android:text="0"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/renegotiate_date_label"
            android:textSize="12sp"
            android:textColor="@color/color_on_surface_variant"/>

        <EditText
            android:id="@+id/et_new_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textSize="16sp"
            android:textColor="@color/color_on_surface"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/renegotiate_hint"
            android:textSize="11sp"
            android:textColor="@color/color_on_surface_variant"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</ScrollView>
