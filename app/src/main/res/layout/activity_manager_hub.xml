<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Status financeiro / data -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_outline_gold"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Data atual" android:textSize="11sp"
                                android:textColor="@color/color_on_surface_variant"/>
                            <TextView android:id="@+id/tv_date"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="20sp" android:fontFamily="sans-serif-bold"
                                android:textColor="@color/color_on_surface"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical"
                            android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Orçamento" android:textSize="11sp"
                                android:textColor="@color/color_on_surface_variant"/>
                            <TextView android:id="@+id/tv_budget"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="20sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/color_outline_variant"
                        android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Folha salarial" android:textSize="11sp"
                                android:textColor="@color/color_on_surface_variant"/>
                            <TextView android:id="@+id/tv_payroll"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="14sp" android:fontFamily="sans-serif-medium"
                                android:textColor="@color/color_on_surface"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:orientation="vertical"
                            android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Elenco" android:textSize="11sp"
                                android:textColor="@color/color_on_surface_variant"/>
                            <TextView android:id="@+id/tv_squad_info"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="14sp" android:fontFamily="sans-serif-medium"
                                android:textColor="@color/color_on_surface"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Próxima partida -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_outline_gold"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PRÓXIMA PARTIDA"
                        android:textSize="11sp" android:fontFamily="sans-serif-medium"
                        android:textColor="@color/color_primary"
                        android:letterSpacing="0.1"/>

                    <TextView android:id="@+id/tv_next_match"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textSize="18sp" android:fontFamily="sans-serif-bold"
                        android:textColor="@color/color_on_surface"/>

                    <TextView android:id="@+id/tv_next_match_date"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/color_on_surface_variant"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_play_next_match"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="▶  Jogar Próxima Partida"
                        android:textSize="14sp"
                        app:cornerRadius="8dp"/>

                    <!-- Avançar dia: progride o calendário em 1 dia processando os
                         ticks diários (scouting, moral, economia). Útil na
                         pré-temporada e entre partidas para ver o scouting evoluir. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_advance_day"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:text="⏭  Avançar 1 dia"
                        android:textSize="13sp"
                        app:cornerRadius="8dp"/>

                    <!-- Status da janela de transferência (mercado aberto/fechado).
                         Texto + cor definidos em código (renderMarketWindow). -->
                    <TextView android:id="@+id/tv_hub_market_window"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:paddingVertical="6dp"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:background="@color/color_surface_elevated"
                        android:textColor="@color/color_on_surface_variant"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

<!-- Cards de navegação -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginTop="10dp">

                <androidx.cardview.widget.CardView android:id="@+id/card_squad"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👥" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Elenco" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/card_market"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💼" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mercado" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/card_schedule"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📅" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Calendário" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/card_standings"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏆" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Classificação" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card MEU PERFIL -->
                <androidx.cardview.widget.CardView android:id="@+id/card_coach_profile"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/coach_default_avatar" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Meu Perfil" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_coach_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                        <!-- Mantido (oculto) para compatibilidade com o código que seta o nome -->
                        <TextView android:id="@+id/tv_hub_coach_name"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card PATROCÍNIOS -->
                <androidx.cardview.widget.CardView android:id="@+id/card_sponsors"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💼" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Patrocínios" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_sponsors_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card TREINOS -->
                <androidx.cardview.widget.CardView android:id="@+id/card_training"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏋️" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Treinos" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_training_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card OLHEIROS -->
                <androidx.cardview.widget.CardView android:id="@+id/card_scouting"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔍" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Olheiros" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_scouting_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card FOLHA SALARIAL -->
                <androidx.cardview.widget.CardView android:id="@+id/card_payroll"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/folha_salarial" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_payroll_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card PROPOSTAS RECEBIDAS -->
                <androidx.cardview.widget.CardView android:id="@+id/card_offers"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📩" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Propostas" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_offers_badge"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card CATEGORIA DE BASE -->
                <androidx.cardview.widget.CardView android:id="@+id/card_academy"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌱" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Base" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_academy_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card BANCO (empréstimos emergenciais + saúde financeira) -->
                <androidx.cardview.widget.CardView android:id="@+id/card_bank"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏦" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Banco" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_bank_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card NOTÍCIAS (feed de esports) -->
                <androidx.cardview.widget.CardView android:id="@+id/card_news"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📰" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Notícias" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_news_subtitle"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:paddingHorizontal="4dp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <!-- Card HISTÓRICO COMPLETO (todos os eventos da carreira, com filtros) -->
                <androidx.cardview.widget.CardView android:id="@+id/card_history"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:layout_height="100dp" android:layout_margin="4dp"
                    android:foreground="?attr/selectableItemBackground" android:clickable="true"
                    android:focusable="true" app:cardCornerRadius="2dp" app:cardElevation="0dp"
                    app:strokeColor="@color/color_outline_gold" app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📜" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/recent_history_card_title" android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:textColor="@color/color_on_surface"/>
                        <TextView android:id="@+id/tv_hub_history_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/champion_gold"
                            android:maxLines="1" android:ellipsize="end"
                            android:visibility="gone"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <!-- Log -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HISTÓRICO RECENTE"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:textColor="@color/color_primary"
                android:letterSpacing="0.1"
                android:layout_marginTop="14dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Atalho para o histórico completo (com filtros e scroll). -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_history_see_all"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recent_history_see_all"
                android:textColor="@color/color_primary"
                android:textSize="12sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_quit"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Encerrar carreira"
                android:textColor="@color/state_danger"/>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
