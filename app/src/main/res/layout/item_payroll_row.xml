<?xml version="1.0" encoding="utf-8"?>
<!--
    Linha da folha salarial. Mostra:
      [barra role] TOP  Robo            R$ 120.000   28%
                                        Ativo
    Toque abre o PlayerDetailDialog para renegociar.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/view_pr_role_bar"
        android:layout_width="3dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"/>

    <TextView
        android:id="@+id/tv_pr_role"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:textColor="@color/color_on_surface_variant"
        android:textSize="11sp"
        android:textStyle="bold"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_pr_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_pr_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:layout_marginTop="1dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_pr_salary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/champion_gold"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_pr_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_on_surface_variant"
            android:textSize="10sp"
            android:layout_gravity="end"
            android:layout_marginTop="1dp"/>
    </LinearLayout>
</LinearLayout>
