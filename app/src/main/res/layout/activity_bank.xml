<?xml version="1.0" encoding="utf-8"?>
<!--
    BankActivity — banco do clube (empréstimos emergenciais).

    Estrutura:
      ┌─ Toolbar (cor do time)
      ├─ Header: saúde financeira (🟢/🟡/🔴) + orçamento + crédito disponível
      ├─ TabLayout: [EMPRÉSTIMOS] [MINHAS DÍVIDAS]
      └─ RecyclerView conforme aba
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_surface">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/bank_title"
            app:titleTextColor="@android:color/white" />

        <!-- Header com saúde financeira -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@color/color_surface_elevated">

            <!-- Faixa de saúde financeira (cor de fundo definida em código) -->
            <TextView
                android:id="@+id/tv_health_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/bank_budget_label"
                        android:textColor="@color/color_on_surface_variant"
                        android:textSize="11sp" android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_bank_budget"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="18sp" android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/bank_credit_label"
                        android:textColor="@color/color_on_surface_variant"
                        android:textSize="11sp" android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_bank_credit"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/champion_gold"
                        android:textSize="18sp" android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Resumo de dívida atual (visível só se houver dívida) -->
            <TextView
                android:id="@+id/tv_bank_debt_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/state_danger"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabIndicatorColor="@color/champion_gold"
            app:tabSelectedTextColor="@color/champion_gold"
            app:tabTextColor="@color/color_on_surface_variant" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/color_on_surface_variant"
        android:textSize="14sp"
        android:padding="32dp"
        android:gravity="center"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
