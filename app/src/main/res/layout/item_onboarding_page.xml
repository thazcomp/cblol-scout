<?xml version="1.0" encoding="utf-8"?>
<!--
    Item de página do ViewPager2 do onboarding.

    Estrutura: ScrollView (fillViewport=true) → LinearLayout vertical
    com gravity=center. Comportamento dual:

      - Conteúdo CABE na viewport → fillViewport estica o LinearLayout até a
        altura do ScrollView, e gravity=center centraliza os 3 elementos.
        Slides curtos mantêm a estética original (emoji centralizado).
      - Conteúdo MAIOR que a viewport → o LinearLayout cresce além e o
        ScrollView ativa o scroll vertical. Slides longos (Aviso Legal,
        Pick & Ban, Patrocínios…) rolam até o fim sem cortar.

    NOTA: não use `android:minHeight="match_parent"` — não é uma dimensão
    válida (parser do Android trata como 0). Quem cuida da altura mínima é
    o `android:fillViewport="true"` do ScrollView; o LinearLayout fica com
    `wrap_content` puro e cresce se precisar.

    Por que ScrollView e não NestedScrollView? O ViewPager2 já distingue bem
    gestos horizontais (page swipe) de verticais (scroll dentro do item) —
    ScrollView simples basta e é mais leve.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        tools:ignore="UselessParent">

        <TextView
            android:id="@+id/tv_onboarding_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="80sp"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            tools:text="🏆"/>

        <TextView
            android:id="@+id/tv_onboarding_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/champion_gold"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.02"
            tools:text="Aviso Legal · Riot Games"/>

        <TextView
            android:id="@+id/tv_onboarding_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/color_on_surface"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.35"
            tools:text="Descrição multilinha do slide com texto longo que pode rolar verticalmente quando excede a viewport disponível…"/>

    </LinearLayout>
</ScrollView>
