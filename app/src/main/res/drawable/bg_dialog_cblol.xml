<?xml version="1.0" encoding="utf-8"?>
<!--
    Fundo dos AlertDialogs do app:
    - Gradient navy escuro (top → bottom)
    - Borda dourada de 1dp em volta
    - Cantos suavemente arredondados (4dp)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:angle="270"
        android:startColor="#363A6E"
        android:endColor="#262952" />

    <stroke
        android:width="1dp"
        android:color="#F0B638" />

    <corners android:radius="4dp" />
</shape>
