<?xml version="1.0" encoding="utf-8"?>
<!--
    Fundo para os "chips" de ações secundárias na seção "Gerenciamento" do Hub.

    Cards principais (Elenco, Calendário, Classificação, Mercado, Propostas,
    Histórico) continuam com a borda dourada cheia em CardView para reforçar
    hierarquia. Os secundários (Patrocínios, Banco, Folha, Treinos, Olheiros,
    Base, Perfil) usam ESTE drawable: fundo elevado discreto com borda 0.5dp,
    sem o dourado dominante. Resultado: visualmente "secundário" sem deixar
    de ser tocável e nem perder funcionalidade.

    Tem state_pressed para feedback de toque, já que essa view usa background
    custom (selectableItemBackground não cabe junto sem foreground em API<23).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_outline_variant"/>
            <stroke android:width="0.5dp" android:color="@color/color_outline_gold"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color_surface_elevated"/>
            <stroke android:width="0.5dp" android:color="@color/color_outline_variant"/>
            <corners android:radius="6dp"/>
        </shape>
    </item>
</selector>
