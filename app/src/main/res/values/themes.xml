<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CBLOLScout" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorSecondary">@color/color_primary_light</item>
        <item name="colorOnSecondary">@color/color_on_primary</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorError">@color/state_danger</item>
        <item name="android:windowBackground">@color/bg_screen</item>
        <item name="android:statusBarColor">@color/bg_screen</item>
        <item name="android:navigationBarColor">@color/bg_screen</item>
        <item name="android:textColorPrimary">@color/color_on_surface</item>
        <item name="android:textColorSecondary">@color/color_on_surface_variant</item>
        <item name="android:textColorHint">@color/color_on_surface_variant</item>
        <item name="materialButtonStyle">@style/Widget.CBLOLScout.Button</item>
    </style>

    <!-- Tema translúcido compatível com AppCompat.
         Usado pelo PickBanRouterActivity, que não tem UI própria mas
         estende AppCompatActivity — não pode usar Theme.Translucent do framework. -->
    <style name="Theme.CBLOLScout.Translucent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Botão "ouro" no estilo do client -->
    <style name="Widget.CBLOLScout.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="cornerRadius">2dp</item>
        <item name="rippleColor">@color/color_primary_light</item>
    </style>

    <style name="ThemeOverlay.CBLOLScout.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="bottomSheetStyle">@style/BottomSheet.CBLOLScout</item>
    </style>

    <style name="BottomSheet.CBLOLScout" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.CBLOLScout.BottomSheet</item>
        <item name="backgroundTint">@color/color_surface</item>
    </style>

    <style name="ShapeAppearance.CBLOLScout.BottomSheet" parent="">
        <item name="cornerFamily">cut</item>
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════
         DIALOG ESTILO LOL — usado em todos os AlertDialogs do app
         Fundo navy escuro com borda dourada e cantos retos.
         ═══════════════════════════════════════════════════════════════ -->
    <style name="ThemeOverlay.CBLOLScout.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/CBLOLScout.Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/CBLOLScout.Dialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/CBLOLScout.Dialog.PositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/CBLOLScout.Dialog.NeutralButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/CBLOLScout.Dialog.NeutralButton</item>

        <!-- Background da CAIXA externa (drawable navy + borda dourada) -->
        <item name="android:background">@drawable/bg_dialog_cblol</item>
        <item name="dialogCornerRadius">4dp</item>

        <!-- Os painéis internos do MaterialAlertDialog usam um
             MaterialShapeDrawable baseado em `shapeAppearanceMediumComponent`
             colorido por `colorSurface`. Para não desenhar nada, sobrescrevemos
             o shape com `nothing` e o background dos painéis com transparente. -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CBLOLScout.Dialog.Empty</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.CBLOLScout.Dialog.Empty</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.CBLOLScout.Dialog</item>

        <!-- Tudo de surface fica transparente para o drawable externo aparecer -->
        <item name="colorSurface">@android:color/transparent</item>
        <item name="colorBackgroundFloating">@android:color/transparent</item>
        <item name="colorSurfaceContainerHigh">@android:color/transparent</item>
        <item name="colorSurfaceContainer">@android:color/transparent</item>
        <item name="colorSurfaceVariant">@android:color/transparent</item>
        <item name="android:colorBackground">@android:color/transparent</item>
        <item name="backgroundColor">@android:color/transparent</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="android:textColorPrimary">@color/color_on_surface</item>
        <item name="android:textColorSecondary">@color/color_on_surface_variant</item>

        <!-- Remove dividers entre título / mensagem / botões -->
        <item name="android:divider">@null</item>
        <item name="android:dividerHeight">0dp</item>
        <item name="android:showDividers">none</item>
    </style>

    <!-- Shape vazio: usado para anular o shape arredondado que o MaterialAlertDialog
         desenha em cada painel interno (título, mensagem). -->
    <style name="ShapeAppearance.CBLOLScout.Dialog.Empty" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>

    <style name="CBLOLScout.Dialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CBLOLScout.Dialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/color_on_surface</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CBLOLScout.Dialog.PositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="rippleColor">@color/color_primary_dark</item>
    </style>

    <style name="CBLOLScout.Dialog.NeutralButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/color_on_surface_variant</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="BanSlot">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:scaleType">centerCrop</item>
        <item name="android:background">@color/champion_slot_bg</item>
    </style>

    <style name="BanSlot.Blue">
        <item name="android:background">@drawable/bg_ban_slot_blue</item>
    </style>

    <style name="BanSlot.Red">
        <item name="android:background">@drawable/bg_ban_slot_red</item>
    </style>

</resources>
