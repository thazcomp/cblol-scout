<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══ Paleta CBLOL Scout — versão VIVID ═══
         Mantém DNA esports/LoL mas com saturação alta para parecer um
         broadcast moderno em vez de um menu sóbrio. Cores anteriores
         estavam dessaturadas (~40-60%); estas estão em 70-95%.
         Backgrounds permanecem escuros para destacar os acentos. -->

    <!-- ── Backgrounds (azul-noite com um toque ROXO para sair do navy plano) ── -->
    <color name="bg_screen">#0A0B1A</color>
    <color name="color_surface">#161830</color>
    <color name="color_surface_elevated">#1F2240</color>

    <!-- ── Texto (creme mais quente, branco puro pra contraste em headers) ── -->
    <color name="color_on_surface">#F5EDD8</color>
    <color name="color_on_surface_variant">#A8A2BD</color>

    <!-- ── Dourado CBLOL (primary) — saturação levada de #C89B3C para tom mais quente ── -->
    <color name="color_primary">#F0B638</color>
    <color name="color_primary_light">#FFD876</color>
    <color name="color_primary_dark">#8B6418</color>
    <color name="color_on_primary">#0A0B1A</color>

    <!-- ── Containers ── -->
    <color name="color_primary_container">#2A2D55</color>
    <color name="color_on_primary_container">#FFD876</color>
    <color name="color_secondary_container">#1F2240</color>
