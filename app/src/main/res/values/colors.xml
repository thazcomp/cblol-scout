    <!-- ── Bordas ── -->
    <color name="color_outline">#4A4970</color>
    <color name="color_outline_variant">#2A2D55</color>
    <color name="color_outline_gold">#B88822</color>

    <!-- ── Raridade (overall do jogador) — gradiente vivo: dourado→ciano→lavanda→cinza ── -->
    <color name="rarity_mythic">#F0B638</color>     <!-- 85+ : dourado vivo -->
    <color name="rarity_legendary">#1FE0CC</color>  <!-- 75-84 : ciano elétrico -->
    <color name="rarity_epic">#C994FF</color>       <!-- 65-74 : lavanda néon -->
    <color name="rarity_rare">#8FA3B8</color>       <!-- < 65 : cinza azulado -->

    <!-- ── Estados (verde/amarelo/vermelho saturados) ── -->
